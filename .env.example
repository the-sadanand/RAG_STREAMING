# ════════════════════════════════════════════════════════════
#  RAG Streaming — .env configuration
#  Copy this to .env and fill in your keys
# ════════════════════════════════════════════════════════════

# ── Embeddings: LOCAL by default ─────────────────────────────
# No API key needed. Uses sentence-transformers (all-MiniLM-L6-v2)
# already installed inside Docker. Change to "gemini" or "openai"
# only if you want cloud embeddings.
EMBEDDING_PROVIDER=local

# ── LLM: Groq (FREE — recommended) ───────────────────────────
# 1. Go to https://console.groq.com
# 2. Sign up (free, no credit card)
# 3. API Keys → Create key → paste below
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── LLM: Gemini (free alternative) ───────────────────────────
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_LLM_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ── LLM: OpenAI (paid) ───────────────────────────────────────
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# ── LLM provider selection ────────────────────────────────────
# auto = Groq if key set, else Gemini, else OpenAI, else fallback
LLM_PROVIDER=auto

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Storage (inside Docker volumes) ──────────────────────────
VECTOR_DB_PATH=/data/chromadb
UPLOAD_PATH=/data/uploads

# ── RAG tuning ────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RESULTS=5
MAX_FILE_SIZE_MB=20
